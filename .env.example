# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/juniper_ai
# SQLAlchemy async pool (defaults match juniper_ai.app.config Settings)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10

# Juniper API (xml-uat / WebServiceJP — Flicknmix test credentials from supplier email)
# WSDL: https://xml-uat.bookingengine.es/webservice/JP/WebServiceJP.asmx?WSDL
# Availability search (HotelAvail): UAT / TestXMLFlicknmix account must pass
# HotelCodes (JPCodes) — DestinationZone is rejected with REQ_PRACTICE
# (Juniper support ticket 1096690). The agent resolves JPCodes from the
# local static cache (`hotel_cache`) and calls HotelAvail in parallel batches.
JUNIPER_API_URL=https://xml-uat.bookingengine.es
JUNIPER_EMAIL=TestXMLFlicknmix
# Password may contain quotes/hash — wrap in single quotes in .env, e.g. JUNIPER_PASSWORD='...'
JUNIPER_PASSWORD=change-me-use-quoted-string-if-special-chars
JUNIPER_USE_MOCK=true

# HotelAvail batching (HotelCodes path). Defaults match juniper_ai.app.config Settings.
# - HOTEL_AVAIL_BATCH_SIZE: JPCodes per single HotelAvail SOAP request.
#   Juniper recommends keeping each request small; 25 is a safe upper bound.
# - HOTEL_AVAIL_BATCH_CONCURRENCY: max parallel batches per search_hotels call.
#   Bounded by asyncio.Semaphore; raise cautiously to avoid rate-limiting.
# - HOTEL_AVAIL_MAX_CANDIDATES: hard cap on JPCodes pulled from the local cache
#   before batching. Protects against unbounded fan-out on very large zones
#   (e.g. a country-level DestinationZone with 10k+ hotels).
# HOTEL_AVAIL_BATCH_SIZE=25
# HOTEL_AVAIL_BATCH_CONCURRENCY=3
# HOTEL_AVAIL_MAX_CANDIDATES=200

# LLM
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Auth
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
API_KEYS=test-api-key-1,test-api-key-2

# Rate Limiting
RATE_LIMIT_USER=60
RATE_LIMIT_API_KEY=300

# App
APP_ENV=development
LOG_LEVEL=INFO

# Conversations (optional; defaults in juniper_ai.app.config)
# MAX_MESSAGE_HISTORY=20
