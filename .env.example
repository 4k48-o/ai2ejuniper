# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5433/juniper_ai
# SQLAlchemy async pool (defaults match juniper_ai.app.config Settings)
DB_POOL_SIZE=10
DB_MAX_OVERFLOW=10

# Juniper API (xml-uat / WebServiceJP — Flicknmix test credentials from supplier email)
# WSDL: https://xml-uat.bookingengine.es/webservice/JP/WebServiceJP.asmx?WSDL
# Availability search (HotelAvail): UAT / TestXMLFlicknmix account must pass
# HotelCodes (JPCodes) — DestinationZone is rejected with REQ_PRACTICE
# (Juniper support ticket 1096690). The agent resolves JPCodes from the
# local static cache (`hotel_cache`) and calls HotelAvail in parallel batches.
JUNIPER_API_URL=https://xml-uat.bookingengine.es
JUNIPER_EMAIL=TestXMLFlicknmix
# Password may contain quotes/hash — wrap in single quotes in .env, e.g. JUNIPER_PASSWORD='...'
JUNIPER_PASSWORD=change-me-use-quoted-string-if-special-chars
# IM / 本地对话联调务必为 true；false 会直连 UAT SOAP（需白名单，且与 MockJuniperClient 行为不一致）。
JUNIPER_USE_MOCK=true

# HotelAvail batching (HotelCodes path). Defaults match juniper_ai.app.config Settings.
# - HOTEL_AVAIL_BATCH_SIZE: JPCodes per single HotelAvail SOAP request.
#   Juniper recommends keeping each request small; 25 is a safe upper bound.
# - HOTEL_AVAIL_BATCH_CONCURRENCY: max parallel batches per search_hotels call.
#   Bounded by asyncio.Semaphore; raise cautiously to avoid rate-limiting.
# - HOTEL_AVAIL_MAX_CANDIDATES: hard cap on JPCodes pulled from the local cache
#   before batching. Protects against unbounded fan-out on very large zones
#   (e.g. a country-level DestinationZone with 10k+ hotels).
# HOTEL_AVAIL_BATCH_SIZE=25
# HOTEL_AVAIL_BATCH_CONCURRENCY=3
# HOTEL_AVAIL_MAX_CANDIDATES=200

# HotelAvail AdvancedOptions — controls which optional fields Juniper sends
# back on availability responses. See doc/juniper-hotel-api.md §HotelAvail and
# §Context for details.
# - JUNIPER_AVAIL_CONTEXT: XML attribute on HotelAvailRQ. Allowed values:
#     FULLAVAIL       (default; multi-hotel search per destination)
#     SINGLEAVAIL     (single-hotel detail lookup)
#     CACHEROBOT / CACHEMETASEARCH / VALUATION / BOOKING / STDDOWNLOAD / ...
# - JUNIPER_AVAIL_SHOW_HOTEL_INFO: required=true to get hotel name/address/
#     category in the response (without this, the `name` field is always empty).
# - JUNIPER_AVAIL_SHOW_CANCELLATION_POLICIES: true returns per-option
#     CancellationPolicy (may be absent on some hotels even when requested).
# - JUNIPER_AVAIL_SHOW_ONLY_AVAILABLE: true drops rooms with no inventory,
#     keeping responses compact. Flip to false for full-catalogue dumps.
# - JUNIPER_AVAIL_TIMEOUT_MS: AdvancedOptions/TimeOut in milliseconds.
#     Juniper caps this at 8000; higher values are silently clamped server-side.
# JUNIPER_AVAIL_CONTEXT=FULLAVAIL
# JUNIPER_AVAIL_SHOW_HOTEL_INFO=true
# JUNIPER_AVAIL_SHOW_CANCELLATION_POLICIES=true
# JUNIPER_AVAIL_SHOW_ONLY_AVAILABLE=true
# JUNIPER_AVAIL_TIMEOUT_MS=8000

# HotelCheckAvail @Context — SINGLEAVAIL (default) or VALUATION per docs.
# Empty string disables the attribute entirely.
# JUNIPER_CHECK_AVAIL_CONTEXT=SINGLEAVAIL

# HotelBookingRules @Context — VALUATION (default), BOOKING, or PAYMENT per
# docs §HotelBookingRules Request. Empty string disables the attribute.
# JUNIPER_BOOKING_RULES_CONTEXT=VALUATION

# HotelBooking @Context — BOOKING (default) or PAYMENT per docs §HotelBooking.
# Empty string disables the attribute.
# JUNIPER_BOOKING_CONTEXT=BOOKING

# HotelBooking price tolerance — fraction above the HotelBookingRules total
# accepted as `PriceRange/@Maximum`. 0.0 = strict (fail on any upward drift);
# 0.02 = accept up to +2%. Downward drift always passes. Juniper rejects the
# booking server-side if the quote falls outside this window.
# JUNIPER_BOOKING_PRICE_TOLERANCE_PCT=0.0

# LLM
LLM_PROVIDER=anthropic
LLM_MODEL=claude-sonnet-4-20250514
ANTHROPIC_API_KEY=your-anthropic-api-key
OPENAI_API_KEY=your-openai-api-key

# Auth
JWT_SECRET_KEY=your-jwt-secret-key-change-in-production
API_KEYS=test-api-key-1,test-api-key-2

# Rate Limiting
RATE_LIMIT_USER=60
RATE_LIMIT_API_KEY=300

# App
APP_ENV=development
LOG_LEVEL=INFO

# Conversations (optional; defaults in juniper_ai.app.config)
# MAX_MESSAGE_HISTORY=20
